# Supabase Configuration
# Get these values from your Supabase project dashboard
# https://supabase.com/dashboard/project/_/settings/api

# Public URL of your Supabase project (safe to expose)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Anonymous/public key (safe to expose, respects RLS policies)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service role key (NEVER expose to client - bypasses RLS)
# Only use this in server-side code that needs admin privileges
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Your application's public URL (for OAuth callbacks)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
